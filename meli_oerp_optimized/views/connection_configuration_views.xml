<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 
        Vista standalone para configuración de optimización.
        No hereda de una vista específica para evitar errores de ID.
    -->
    <record id="view_mercadolibre_configuration_form_optimized" model="ir.ui.view">
        <field name="name">mercadolibre.configuration.form.optimized</field>
        <field name="model">mercadolibre.configuration</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="⚡ Optimización del Cron (Odoo.sh)">
                        <group>
                            <field name="mercadolibre_cron_batch_size"/>
                            <field name="mercadolibre_cron_max_time"/>
                        </group>
                        <group>
                            <field name="mercadolibre_cron_orders_per_page"/>
                            <field name="mercadolibre_cron_use_queue"/>
                        </group>
                        <group colspan="2">
                            <field name="mercadolibre_cron_last_offset" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>