<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_payment_register_form_expense" model="ir.ui.view">
        <field name="name">account.payment.register.form.expense</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="account.view_account_payment_register_form"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <field name="journal_id" position="after">
                <field name="receiptbook_id" 
                       string="Talonario de Recibo"
                       options="{'no_create': True, 'no_open': True}"
                       invisible="not journal_id"/>
            </field>
        </field>
    </record>

</odoo>