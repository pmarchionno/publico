<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 
        Vista del wizard account.payment.register extendida para:
        1. Mostrar receiptbook_id para seleccionar talonario
        2. Mostrar pestaña de Pagos cuando el método es payment_bundle
    -->
    <record id="view_account_payment_register_form_expense" model="ir.ui.view">
        <field name="name">account.payment.register.form.expense</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="account.view_account_payment_register_form"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            
            <!-- Campos ocultos necesarios -->
            <form position="inside">
                <field name="is_payment_bundle" invisible="1"/>
                <field name="is_from_expense" invisible="1"/>
            </form>
            
            <!-- Talonario de Recibo después del método de pago -->
            <field name="payment_method_line_id" position="after">
                <field name="receiptbook_id" 
                       string="Talonario de Recibo"
                       options="{'no_create': True, 'no_open': True}"
                       invisible="not journal_id"/>
            </field>
            
            <!-- Sección de Pagos Múltiples (visible solo con payment_bundle) -->
            <xpath expr="//footer" position="before">
                <group invisible="not is_payment_bundle" col="1">
                    <separator string="Líneas de Pago"/>
                    <field name="payment_line_ids" nolabel="1">
                        <tree editable="bottom">
                            <field name="journal_id" 
                                   options="{'no_create': True}"
                                   required="1"/>
                            <field name="payment_method_line_id" 
                                   options="{'no_create': True}"
                                   optional="hide"/>
                            <field name="amount" sum="Total" required="1"/>
                            <field name="receiptbook_id" 
                                   options="{'no_create': True}"
                                   optional="show"/>
                        </tree>
                    </field>
                    <group col="2">
                        <field name="payment_lines_total" string="Total en líneas"/>
                        <field name="payment_lines_difference" string="Diferencia"
                               decoration-danger="payment_lines_difference != 0"
                               decoration-success="payment_lines_difference == 0"/>
                    </group>
                </group>
            </xpath>
            
            <!-- Ocultar el monto principal cuando es payment_bundle -->
            <field name="amount" position="attributes">
                <attribute name="invisible">is_payment_bundle</attribute>
            </field>
            
        </field>
    </record>

</odoo>
