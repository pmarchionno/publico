<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Setting: Display discount with or without tax -->
    <record id="res_config_settings_view_form_display_discount_with_tax" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.discount.display</field>
        <field name="model">res.config.settings</field>
        <field name="priority">99</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='discount_sale_order_lines']" position="after">
                <setting
                    id="discount_display_amount"
                    string="Discount Display Mode"
                    help="OFF = Shows the Discount without TAX. ON = Shows the Discount with TAX">
                    <field name="display_discount_with_tax"/>
                </setting>
            </xpath>
        </field>
    </record>

    <!-- Setting: Show total without discount in report -->
    <record id="res_config_settings_view_form_report_total_without_discount" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.report.total.without.discount</field>
        <field name="model">res.config.settings</field>
        <field name="priority">99</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='proforma_configuration']" position="after">
                <setting
                    id="report_total_without_discount"
                    string="Report Total Without Discount"
                    help='Display "Total without discount" in sales report'>
                    <field name="report_total_without_discount"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
