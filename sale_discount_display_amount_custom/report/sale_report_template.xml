<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- 
        This template adds discount information to the sale order report.
        In Odoo 17, the totals section structure changed significantly.
        We insert our content at the end of the total div using a safe XPath.
    -->
    <template
        id="sale_discount_display_amount_document"
        inherit_id="sale.report_saleorder_document"
    >
        <!-- Insert discount rows in the total summary section -->
        <xpath expr="//div[@name='so_total_summary']" position="inside">
            <t t-if="doc.discount_total" groups="product.group_discount_per_so_line">
                <div class="row">
                    <div t-attf-class="#{'col-6' if report_type != 'html' else 'col-sm-7 col-md-6'} ms-auto">
                        <table class="table table-sm table-borderless">
                            <!-- Show Total Without Discount if enabled -->
                            <tr t-if="doc.company_id.report_total_without_discount and doc.price_total_no_discount != doc.amount_total">
                                <td><strong>Total Without Discount</strong></td>
                                <td class="text-end">
                                    <span t-field="doc.price_total_no_discount"/>
                                </td>
                            </tr>
                            <!-- Show Discount Amount -->
                            <tr>
                                <td><strong>Discount</strong></td>
                                <td class="text-end">
                                    <span t-field="doc.discount_total"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
