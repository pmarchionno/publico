# =============================================================================
# Configuración del SDK de Payway
# =============================================================================
# Copia este archivo como .env y completa con tus credenciales

# Credenciales de API (REQUERIDAS)
# Obtén tus credenciales en: https://developers.decidir.com
PAYWAY_PUBLIC_KEY=pk_test_xxxxxxxx
PAYWAY_PRIVATE_KEY=sk_test_xxxxxxxx

# Entorno: sandbox o production
PAYWAY_ENVIRONMENT=sandbox

# ID del sitio/comercio (opcional)
# PAYWAY_SITE_ID=00000001

# =============================================================================
# Configuración HTTP
# =============================================================================

# Timeout en segundos para requests
PAYWAY_TIMEOUT=30.0

# Timeout de conexión en segundos
PAYWAY_CONNECT_TIMEOUT=10.0

# Número máximo de reintentos
PAYWAY_MAX_RETRIES=3

# =============================================================================
# Logging
# =============================================================================

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
PAYWAY_LOG_LEVEL=INFO

# Log de requests/responses (cuidado: puede exponer datos sensibles)
PAYWAY_LOG_REQUESTS=false

# Enmascarar datos sensibles en logs
PAYWAY_MASK_SENSITIVE_DATA=true
