<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Fix para recibo de pago con retenciones.
        
        El problema original: En pagos con retenciones, la línea de transferencia
        mostraba amount_signed (total con retenciones) en lugar de amount (neto).
        
        Esta corrección reemplaza el bloque de la línea de transferencia para
        usar doc.amount (neto) en lugar de doc.amount_signed (total).
    -->
    
    <template id="report_payment_receipt_document_fix" 
              inherit_id="l10n_ar_tax.report_payment_receipt_document" 
              priority="99">
        
        <!-- Reemplazar el bloque de pagos que no son cheques -->
        <xpath expr="//t[@id='payment_bundle_doc']" position="replace">
            <t t-foreach="payment_bundle.filtered(lambda x: not x._is_latam_check_payment() and x.amount != 0.0)" t-as="doc" id="payment_bundle_doc">
                <t t-set="doc_secondary_currency_rate" t-value="doc.exchange_rate if doc.other_currency else doc.counterpart_exchange_rate"/>

                <!-- FIX: Usar doc.amount (neto) en lugar de doc.amount_signed (total con retenciones) -->
                <t t-set="display_amount" t-value="doc.amount"/>
                <t t-set="display_amount_secondary" t-value="secondary_currency.round(display_amount / doc_secondary_currency_rate) if secondary_currency else display_amount"/>
                <t t-set="display_amount_company" t-value="doc.company_currency_id.round(display_amount_secondary * doc_secondary_currency_rate) if doc.other_currency else display_amount"/>
                
                <tr t-if="doc.payment_method_line_id.payment_method_id.code != 'payment_bundle'">
                    <td>
                        <span t-field="doc.journal_id.name"/>
                        <span t-field="doc.payment_method_line_id.name"/>
                    </td>

                    <td class="text-right" t-if="secondary_currency">
                        <span class="text-nowrap"
                            t-out="secondary_currency.round(display_amount_secondary)"
                            t-options='{"widget": "monetary", "display_currency": secondary_currency}'/>
                    </td>

                    <td class="text-right o_price_total">
                        <span class="text-nowrap"
                            t-out="display_amount_company"
                            t-options='{"widget": "monetary", "display_currency": doc.company_currency_id}'/>
                    </td>
                </tr>
            </t>
        </xpath>
        
    </template>
</odoo>
